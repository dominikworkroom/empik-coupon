{
  "info": {
    "_postman_id": "0f7b3f0c-8d9c-4d17-9c26-empik-coupon-service",
    "name": "Empik Coupon Service",
    "description": "Postman collection for user creation, coupon creation and coupon redeem endpoints. Uses X-Test-IP header for local testing.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "userId",
      "value": "1"
    },
    {
      "key": "couponCode",
      "value": "WIOSNA2026"
    },
    {
      "key": "testIpPl",
      "value": "10.1.1.1"
    },
    {
      "key": "testIpDe",
      "value": "20.1.1.1"
    }
  ],
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Create User - PL",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"dzielinski\",\n  \"name\": \"Dominik\",\n  \"surname\": \"Zielinski\",\n  \"countryCode\": \"PL\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "users"
              ]
            },
            "description": "Creates a new PL user."
          },
          "response": []
        },
        {
          "name": "Create User - DE",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"hans\",\n  \"name\": \"Hans\",\n  \"surname\": \"Muller\",\n  \"countryCode\": \"DE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "users"
              ]
            },
            "description": "Creates a new DE user."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Coupons",
      "item": [
        {
          "name": "Create Coupon - PL",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"{{couponCode}}\",\n  \"maxUses\": 5,\n  \"countryCode\": \"PL\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/coupons",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "coupons"
              ]
            },
            "description": "Creates a coupon for PL users."
          },
          "response": []
        },
        {
          "name": "Create Coupon - DE",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"DEALDE2026\",\n  \"maxUses\": 3,\n  \"countryCode\": \"DE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/coupons",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "coupons"
              ]
            },
            "description": "Creates a coupon for DE users."
          },
          "response": []
        },
        {
          "name": "Redeem Coupon - PL Success",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Test-IP",
                "value": "{{testIpPl}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": {{userId}},\n  \"code\": \"{{couponCode}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/coupons/use",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "coupons",
                "use"
              ]
            },
            "description": "Redeems coupon using simulated PL IP."
          },
          "response": []
        },
        {
          "name": "Redeem Coupon - Wrong Country",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Test-IP",
                "value": "{{testIpDe}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": {{userId}},\n  \"code\": \"{{couponCode}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/coupons/use",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "coupons",
                "use"
              ]
            },
            "description": "Negative test. Tries to redeem PL coupon using simulated DE IP."
          },
          "response": []
        },
        {
          "name": "Redeem Coupon - Empty Code Validation",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Test-IP",
                "value": "{{testIpPl}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": {{userId}},\n  \"code\": \"\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/coupons/use",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "coupons",
                "use"
              ]
            },
            "description": "Validation test for empty coupon code."
          },
          "response": []
        }
      ]
    }
  ]
}